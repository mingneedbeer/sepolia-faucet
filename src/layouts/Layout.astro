---
import type { Metadata } from "astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Yet Another Sepolia Faucet",
  description = "Get free Sepolia ETH for testing and development",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-9PLQPP677L"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-9PLQPP677L");
    </script>
  </head>
  <body class="font-sans">
    <slot />
  </body>
</html>

<style is:global>
  body {
    font-family: "Inter", system-ui, sans-serif;
  }
</style>
